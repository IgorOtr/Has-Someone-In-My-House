CAMERA_INDEX=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720

MODEL_PATH=yolo11n.pt
MODEL_IMAGE_SIZE=480
CONFIDENCE_THRESHOLD=0.65
PROCESS_EVERY_N_FRAMES=2

DETECTION_WINDOW_SIZE=5
MINIMUM_POSITIVE_FRAMES=3

CAPTURE_DELAY_SECONDS=0.5
CAPTURE_COOLDOWN_SECONDS=0

IMAGE_DIRECTORY=detections
IMAGE_FORMAT=jpg
IMAGE_JPEG_QUALITY=90
IMAGE_RETENTION_HOURS=24
IMAGE_CLEANUP_INTERVAL_MINUTES=30

LOG_LEVEL=INFO

# Web dashboard authentication (web/) — MySQL user store + JWT tokens
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your-user
DB_PASSWORD=your-password
DB_NAME=your-database

# CHANGE THIS before exposing the dashboard beyond localhost.
JWT_SECRET_KEY=your-dev-secret-change-me
JWT_EXPIRES_MINUTES=120

# Set to false after creating your account(s) to close self-service signup.
ALLOW_PUBLIC_REGISTRATION=true

# WhatsApp alert delivery via Z-API (https://www.z-api.io/). Leaving any of
# these unset disables WhatsApp delivery — alerts are still recorded.
ZAPI_INSTANCE_ID=your-zapi-instance-id
ZAPI_TOKEN=your-zapi-token
ZAPI_CLIENT_TOKEN=your-zapi-client-token
